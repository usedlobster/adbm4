{
  "form": {
    "version": 1,

    "ajax": {
      "url":"https://api.usedlobster.test/api/v1/form/users" ,
      "key" : "sid"
    },
    "title": "Edit User",
    "layout" : {
      "id" : "uf" ,
      "pages" : [
        {
          "sections": [
            {
              "elements": [
                {
                  "type": "text",
                  "field": "u.sid" ,
                  "key" : true ,
                  "hidden" : true
                },
                {
                  "type" : "text" ,
                  "field" : "uname",
                  "label" : "Account Name",
                  "primary" : true
                } ,
                {
                  "type": "number",
                  "field": "level",
                  "label": "Level"
                },

                {
                  "type" : "text" ,
                  "field" : "fname",
                  "label" : "First Name"
                } ,
                {
                  "type" : "text" ,
                  "field" : "lname",
                  "label" : "Last Name"
                } ,
                {
                  "type"  : "select" ,
                  "field" : "cid",
                  "label" : "Company",

                  "datasrc" : {
                      "type" : "named",
                      "name" : "clist"

                  }
                },
                {
                  "type" : "text" ,
                  "field" : "roles",
                  "label" : "Role"
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "table": {
    "version": 1,
    "ajax": {
      "url": "https://api.usedlobster.test/api/v1/table/users"
    },
    "qbar": [
      {
        "type": "btn",
        "name": "Add User",
        "action": "edit"
      },
      {
        "type": "radio",
        "default": 0,
        "filters": [
          {
            "name": "All",
            "value": 0
          },
          {
            "name": "Active",
            "value": 1
          },
          {
            "name": "Inactive",
            "value": -1
          }
        ]
      }
    ],
    "title": "List of Users",
    "columns": [
      {
        "field": "sid",
        "title": "ID",
        "width": 2,
        "sortable": false,
        "type": "button"
      },
      {
        "field": "level",
        "title": "Level",
        "width": 2
      },
      {
        "field": "uname",
        "title": "Username",
        "width": 10
      },
      {
        "field": "fname",
        "title": "Firstname",
        "width": 10
      },
      {
        "field": "lname",
        "title": "Lastname",
        "width": 10
      },
      {
        "field": "rname",
        "title": "Role",
        "width": 10,
        "moveable": false,
        "exportable": false
      },
      {
        "field": "ccode",
        "title": "Code",
        "width": 1
      },
      {
        "field": "cname",
        "title": "Company",
        "width": 20
      }
    ],
    "order": []
  }
}